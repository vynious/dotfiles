// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
    "vim_mode": true,
    "vim": {
        "toggle_relative_line_numbers": true,
    },
    "disable_ai": false,
    "terminal": {
        "font_size": 12.0,
        "detect_venv": {
            "on": {
                "directories": [".env", "env", ".venv", "venv"],
                "activate_script": "default",
            },
        },
    },
    /* Duplicated key auto-commented: "agent": {
        "default_model": {
            "provider": "copilot_chat",
            "model": "gemini-3-pro-preview",
        },
        "always_allow_tool_actions": false,
        "model_parameters": [],
    }, */
    "minimap": {
        "show": "never",
    },
    "auto_indent_on_paste": true,
    "use_on_type_format": true,
    "show_edit_predictions": true,
    "hard_tabs": false,
    "tab_size": 4,
    "file_types": {
        "html": ["*.ejs"],
    },
    "icon_theme": "Colored Zed Icons Theme Dark",
    "collaboration_panel": {
        "dock": "right",
    },
    "outline_panel": {
        "dock": "right",
    },
    "git_panel": {
        "dock": "right",
    },
    "project_panel": {
        "dock": "right",
    },
    "indent_guides": {
        "enabled": true,
        "coloring": "indent_aware",
    },
    "autosave": {
        "after_delay": {
            "milliseconds": 1000,
        },
    },
    "agent": {
        "dock": "left",
    },
    "auto_indent": true,
    "base_keymap": "VSCode",
    "ui_font_size": 15,
    // "ui_font_family": "JetBrains Mono",
    "buffer_font_family": "JetBrains Mono",
    "buffer_font_size": 14,
    "theme": {
        "mode": "dark",
        "light": "One Light",
        "dark": "One Dark",
    },
    "edit_predictions": {
        "mode": "subtle",
        "disabled_globs": [
            "**/.env*",
            "**/*.pem",
            "**/*.key",
            "**/*.cert",
            "**/*.crt",
            "**/.dev.vars",
            "**/secrets.yml",
        ],
    },
    "lsp": {
        "rust-analyzer": {
            "enable_lsp_tasks": true,
            "initialization_options": {
                "inlayHints": {
                    "maxLength": null,
                    "lifetimeElisionHints": {
                        "enable": "skip_trivial",
                        "useParameterNames": true,
                    },
                    "closureReturnTypeHints": {
                        "enable": "always",
                    },
                },
                "rust": {
                    "analyzerTargetDir": "target/rust-analyzer",
                },
            },
        },
    },
    "experimental.theme_overrides": {
        // Add contrast to `hint` and `error` information box
        "error.background": "#5a2222",
        "warning.background": "#5a5a22",
        "error.border": "#b40000",
        "warning.border": "#b48a00",

        // Panel theme setting
        // "pane.focused_border": "#00000000",
        // "border": "#00000000"
    },
    "agent_servers": {
        "gemini": {
            "args": ["-m", "3 Pro"],
        },
    },
}
